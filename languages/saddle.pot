msgstr ""

#: includes/abilities/core-content.php:27
msgid "Approval-gated content operations exposed to AI agents by Saddle."
msgstr ""

#: includes/abilities/core-content.php:46
msgid "Get site info"
msgstr ""

#: includes/abilities/core-content.php:47
msgid "Returns orientation data about this WordPress site: name, tagline, URL, WordPress version, language, content counts (posts, pages, media), the current Saddle access tier, and the connected user. Read-only. Call this first to understand what the site contains before other operations."
msgstr ""

#: includes/abilities/core-content.php:63
msgid "Get instructions"
msgstr ""

#: includes/abilities/core-content.php:64
msgid "Returns important context about this site (its setup and active plugins) and the site owner's instructions for AI agents. Call this first, before other actions, and follow the guidance it returns. Read-only."
msgstr ""

#: includes/abilities/core-content.php:80
msgid "Search content"
msgstr ""

#: includes/abilities/core-content.php:81
msgid "Full-text search across posts and pages by keyword. Returns matching items as summaries (id, type, title, status, link, excerpt). Read-only. Use post_type to restrict to \"post\", \"page\", or \"any\"."
msgstr ""

#: includes/abilities/core-content.php:90
msgid "Search keywords."
msgstr ""

#: includes/abilities/core-content.php:96
msgid "Restrict results to this type."
msgstr ""

#: includes/abilities/core-content.php:117
msgid "List posts"
msgstr ""

#: includes/abilities/core-content.php:118
msgid "Lists posts as summaries (id, title, status, author, date, link, excerpt). Read-only. Supports filtering by status, author, category, and search term, plus pagination via per_page/page."
msgstr ""

#: includes/abilities/core-content.php:127
#: includes/abilities/core-content.php:241
#: includes/abilities/core-content.php:327
#: includes/abilities/core-content.php:536
msgid "Optional keyword filter."
msgstr ""

#: includes/abilities/core-content.php:131
msgid "Filter by author user ID."
msgstr ""

#: includes/abilities/core-content.php:135
msgid "Filter by category term ID."
msgstr ""

#: includes/abilities/core-content.php:160
msgid "Get post"
msgstr ""

#: includes/abilities/core-content.php:161
msgid "Returns a single post in full: title, content, excerpt, status, slug, author, dates, categories, tags, featured image, discussion settings, and custom fields (meta). Read-only."
msgstr ""

#: includes/abilities/core-content.php:163
msgid "The post ID."
msgstr ""

#: includes/abilities/core-content.php:173
msgid "Create post"
msgstr ""

#: includes/abilities/core-content.php:174
msgid "Creates a new post and returns its id and summary. Additive (non-destructive). Accepts title, content, excerpt, status (draft/publish/pending/private), slug, author, date, category_ids, tags, featured_media, discussion settings, and custom fields via \"meta\". Defaults to draft status."
msgstr ""

#: includes/abilities/core-content.php:186
msgid "Update post"
msgstr ""

#: includes/abilities/core-content.php:187
msgid "Updates an existing post by id. Only the fields you pass are changed; omitted fields are left untouched. Accepts the same fields as create-post, including slug, author, and custom fields via \"meta\" (null deletes a key). WordPress stores a revision, so changes are recoverable (non-destructive). Returns the updated summary."
msgstr ""

#: includes/abilities/core-content.php:199
msgid "Delete post"
msgstr ""

#: includes/abilities/core-content.php:200
msgid "Deletes a post. DESTRUCTIVE — runs through a two-step confirmation: the first call returns a preview and a confirm_token without changing anything; call again with confirm_token to execute. Without \"force\" the post is trashed (recoverable); with force=true it is permanently deleted (not recoverable)."
msgstr ""

#: includes/abilities/core-content.php:202
msgid "The post ID to delete."
msgstr ""

#: includes/abilities/core-content.php:212
msgid "List post revisions"
msgstr ""

#: includes/abilities/core-content.php:213
msgid "Lists the stored revisions of a post or page (id, author, date, title). Read-only. Restoring a revision is not available in this version."
msgstr ""

#: includes/abilities/core-content.php:215
msgid "The post or page ID."
msgstr ""

#: includes/abilities/core-content.php:231
msgid "List pages"
msgstr ""

#: includes/abilities/core-content.php:232
msgid "Lists pages as summaries (id, title, status, parent, menu order, link). Read-only. Supports status filtering and pagination."
msgstr ""

#: includes/abilities/core-content.php:245
msgid "Filter by parent page ID."
msgstr ""

#: includes/abilities/core-content.php:260
msgid "Get page"
msgstr ""

#: includes/abilities/core-content.php:261
msgid "Returns a single page in full: title, content, excerpt, status, slug, author, dates, page template, parent, menu order, featured image, discussion settings, and custom fields (meta). Read-only."
msgstr ""

#: includes/abilities/core-content.php:263
msgid "The page ID."
msgstr ""

#: includes/abilities/core-content.php:273
msgid "Create page"
msgstr ""

#: includes/abilities/core-content.php:274
msgid "Creates a new page and returns its id and summary. Additive (non-destructive). Accepts title, content, excerpt, status, slug, author, date, page template, parent, menu_order, featured_media, discussion settings, and custom fields via \"meta\". Defaults to draft status."
msgstr ""

#: includes/abilities/core-content.php:286
msgid "Update page"
msgstr ""

#: includes/abilities/core-content.php:287
msgid "Updates an existing page by id. Only the fields you pass are changed. Accepts the same fields as create-page, including slug, author, and custom fields via \"meta\" (null deletes a key). WordPress stores a revision, so changes are recoverable (non-destructive). Returns the updated summary."
msgstr ""

#: includes/abilities/core-content.php:299
msgid "Delete page"
msgstr ""

#: includes/abilities/core-content.php:300
msgid "Deletes a page. DESTRUCTIVE — two-step confirmation required (preview + confirm_token). Without \"force\" the page is trashed (recoverable); with force=true it is permanently deleted."
msgstr ""

#: includes/abilities/core-content.php:302
msgid "The page ID to delete."
msgstr ""

#: includes/abilities/core-content.php:318
msgid "List media"
msgstr ""

#: includes/abilities/core-content.php:319
msgid "Lists media library items as summaries (id, title, mime type, URL, date, attached post). Read-only. Supports filtering by mime type and parent, plus pagination."
msgstr ""

#: includes/abilities/core-content.php:331
msgid "Filter by MIME type or prefix, e.g. \"image\" or \"image/png\"."
msgstr ""

#: includes/abilities/core-content.php:335
msgid "Filter by the post the media is attached to."
msgstr ""

#: includes/abilities/core-content.php:350
msgid "Get media"
msgstr ""

#: includes/abilities/core-content.php:351
msgid "Returns a single media item in full: URL, MIME type, alt text, caption, description, available image sizes, and the post it is attached to. Read-only."
msgstr ""

#: includes/abilities/core-content.php:353
#: includes/abilities/core-content.php:408
msgid "The attachment ID."
msgstr ""

#: includes/abilities/core-content.php:363
msgid "Upload media from URL"
msgstr ""

#: includes/abilities/core-content.php:364
msgid "Downloads a file from a source URL you provide and adds it to the media library, returning the new attachment id and URL. Additive (non-destructive). This is the only ability that fetches an external URL, and it fetches only the URL you pass. Optionally set title, alt text, caption, description, and the post to attach it to."
msgstr ""

#: includes/abilities/core-content.php:373
msgid "Publicly reachable URL of the file to download."
msgstr ""

#: includes/abilities/core-content.php:377
msgid "Override the stored filename (with extension)."
msgstr ""

#: includes/abilities/core-content.php:385
msgid "Attach the media to this post/page ID."
msgstr ""

#: includes/abilities/core-content.php:398
msgid "Update media metadata"
msgstr ""

#: includes/abilities/core-content.php:399
msgid "Updates a media item's metadata (title, alt text, caption, description) by id. Does not replace the file. Non-destructive. Returns the updated summary."
msgstr ""

#: includes/abilities/core-content.php:425
msgid "Delete media"
msgstr ""

#: includes/abilities/core-content.php:426
msgid "Deletes a media item and its files. DESTRUCTIVE and NOT RECOVERABLE — attachments have no trash state in WordPress, so deletion is permanent. Two-step confirmation required (preview + confirm_token)."
msgstr ""

#: includes/abilities/core-content.php:428
msgid "The attachment ID to delete."
msgstr ""

#: includes/abilities/core-content.php:444
msgid "List categories"
msgstr ""

#: includes/abilities/core-content.php:445
msgid "Lists post categories as summaries (id, name, slug, parent, post count, description). Read-only. Supports search and pagination."
msgstr ""

#: includes/abilities/core-content.php:457
msgid "Create category"
msgstr ""

#: includes/abilities/core-content.php:458
msgid "Creates a post category and returns it. Additive (non-destructive). Accepts name (required), slug, parent category id, and description."
msgstr ""

#: includes/abilities/core-content.php:470
msgid "List tags"
msgstr ""

#: includes/abilities/core-content.php:471
msgid "Lists post tags as summaries (id, name, slug, post count, description). Read-only. Supports search and pagination."
